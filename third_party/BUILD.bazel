load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake", "configure_make")

# ---- GMP 6.3.0 (http_archive) ----
# Arbitrary-precision arithmetic library; used by Nettle/hogweed.
# Not required by any active build target; tagged manual to exclude from //...
configure_make(
    name = "gmp",
    lib_source = "@gmp_src//:all",
    configure_options = [
        "--enable-static",
        "--disable-shared",
        "--disable-cxx",
        "--with-pic",
    ],
    out_static_libs = ["libgmp.a"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

# ---- libtasn1 4.19.0 (http_archive) ----
