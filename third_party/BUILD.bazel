# ---- Nettle 3.9.1 (http_archive) ----
# Cryptographic library; used by GnuTLS.  Requires GMP.
# Not required by any active build target; tagged manual to exclude from //...
configure_make(
    name = "nettle",
    lib_source = "@nettle_src//:all",
    configure_options = [
        "--enable-static",
        "--disable-shared",
        "--disable-documentation",
        "--with-pic",
    ],
    env = {
        # Nettle discovers GMP via CPPFLAGS/LDFLAGS (no --with-gmp-* flags).
        "CPPFLAGS": "-I$$EXT_BUILD_DEPS$$/gmp/include",
        "LDFLAGS": "-L$$EXT_BUILD_DEPS$$/gmp/lib",
    },
    deps = [":gmp"],
    out_static_libs = ["libnettle.a", "libhogweed.a"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

# ---- GNU libmicrohttpd 1.0.1 (http_archive) ----
# Embedded HTTP server used for the fake camera in tests.
# Built without HTTPS (--disable-https) so GnuTLS, GMP, Nettle, libtasn1,
# libunistring, and libp11-kit are NOT required — only pthreads (dynamic/system).
configure_make(
    name = "libmicrohttpd",
    lib_source = "@libmicrohttpd_src//:all",
    configure_options = [
        "--enable-static",
        "--disable-shared",
        "--disable-https",
        "--disable-doc",
        "--with-pic",
    ],
    out_static_libs = ["libmicrohttpd.a"],
    visibility = ["//visibility:public"],
)

# ---- PostgreSQL 16.13 client libraries (http_archive) ----
# We build only the three client-side static libraries by setting targets = []
# (skip the default make+install) and using postfix_script to do a selective build.
#
#   libpq       — C client API
#   libpgcommon — internal utilities shared between client and server
#   libpgport   — platform-portability helpers
#
# Configured without Kerberos (--without-gssapi) and without LDAP
# (--without-ldap), so libkrb5-dev and libldap-dev are NOT required.
# TLS for database connections is provided by the vendored OpenSSL.
#
# libpgcommon.a and libpgport.a install to lib/postgresql/; the postfix_script
# copies them to lib/ where rules_foreign_cc expects out_static_libs.
configure_make(
    name = "libpq",
    lib_source = "@postgres_src//:all",
    configure_options = [
        "--without-readline",
        "--without-icu",
        "--without-zlib",
        "--without-openssl",
        "--without-gssapi",
        "--without-ldap",
    ],
    targets = [],
    postfix_script = """
make -C src/common all
make -C src/port all
# Remove libpq-refs-stamp from the 'all' prerequisite list before building.
# The stamp checks libpq.so for forbidden undefined symbols; it fires for any
# build that injects its own symbols (sanitisers, PGO instrumentation, etc.).
# We only need the static library, so the shared-lib symbol check is irrelevant.
sed -i '/^all:/s/ *libpq-refs-stamp//' src/interfaces/libpq/Makefile
make -C src/interfaces/libpq all
make -C src/common install
make -C src/port install
make -C src/interfaces/libpq install
make -C src/include install
# rules_foreign_cc copies BUILD_TMPDIR/INSTALL_PREFIX → INSTALLDIR *before*
# postfix_script runs (targets=[] so nothing was installed yet at that point).
# Re-sync INSTALLDIR so Bazel finds the archives it declared in out_static_libs.
cp -rp "$$BUILD_TMPDIR/$$INSTALL_PREFIX/." "$$INSTALLDIR/"
# libpgcommon.a and libpgport.a install to lib/postgresql/; copy to lib/
for a in libpgcommon.a libpgport.a; do
  src="$$INSTALLDIR/lib/postgresql/$$a"
  if [ -f "$$src" ]; then cp "$$src" "$$INSTALLDIR/lib/"; fi
done
""",
    out_static_libs = ["libpq.a", "libpgcommon.a", "libpgport.a"],
    visibility = ["//visibility:public"],
)

# ---- NCNN (downloaded via http_archive) ----
# x86 host build -- native, no cross-compilation flags needed.
cmake(
    name = "ncnn",
    lib_source = "@ncnn//:all",
    out_static_libs = ["libncnn.a"],
    cache_entries = {
        "NCNN_BUILD_TOOLS": "OFF",
        "NCNN_BUILD_EXAMPLES": "OFF",
        "NCNN_VULKAN": "OFF",
        "NCNN_BUILD_TESTS": "OFF",
        "NCNN_BUILD_BENCHMARK": "OFF",
        "NCNN_OPENMP": "OFF",
        "NCNN_SHARED_LIB": "OFF",
    },
    visibility = ["//visibility:public"],
)

# ARM64 cross-compiled build.
# CMAKE_SYSTEM_NAME + CMAKE_SYSTEM_PROCESSOR tell CMake we are cross-compiling:
#   - try_run() checks are skipped (ARM64 binaries can't execute on the x86 host)
#   - NCNN detects aarch64 and enables NEON SIMD intrinsics automatically
# The Bazel ARM64 toolchain wrapper already passes --sysroot and
# -target aarch64-linux-gnu to clang via the rules_foreign_cc toolchain file,
# so no additional sysroot or compiler flags are needed here.
cmake(
    name = "ncnn_arm64",
    lib_source = "@ncnn//:all",
    out_static_libs = ["libncnn.a"],
    cache_entries = {
        "NCNN_BUILD_TOOLS": "OFF",
        "NCNN_BUILD_EXAMPLES": "OFF",
        "NCNN_VULKAN": "OFF",
        "NCNN_BUILD_TESTS": "OFF",
        "NCNN_BUILD_BENCHMARK": "OFF",
        "NCNN_OPENMP": "OFF",
        "NCNN_SHARED_LIB": "OFF",
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_SYSTEM_PROCESSOR": "aarch64",
        "CMAKE_CROSSCOMPILING": "TRUE",
    },
    visibility = ["//visibility:public"],
)

# ---- libjpeg-turbo (git submodule: third_party/libjpeg-turbo) ----
cmake(
    name = "libjpeg_turbo",
    lib_source = "@libjpeg_turbo//:all",
    out_static_libs = ["libjpeg.a"],
    cache_entries = {
        "ENABLE_SHARED": "OFF",
        "WITH_TURBOJPEG": "OFF",
        "WITH_JAVA": "OFF",
        "CMAKE_INSTALL_LIBDIR": "lib",
    },
    visibility = ["//visibility:public"],
)

# ---- OpenSSL (git submodule: third_party/openssl) ----
# Uses OpenSSL's Perl-based Configure script via rules_foreign_cc configure_make.
configure_make(
    name = "openssl",
    lib_source = "@openssl_src//:all",
    configure_command = "Configure",
    configure_in_place = True,
    configure_options = [
        "linux-x86_64",
        "--libdir=lib",
        "no-shared",
        "no-tests",
        "no-apps",
        "no-docs",
    ],
    env = {"PERL": "perl"},
    out_static_libs = [
        "libssl.a",
        "libcrypto.a",
    ],
    visibility = ["//visibility:public"],
)

# ---- libxml2 (git submodule: third_party/libxml2) ----
# Minimal build: no Python, ICU, lzma, zlib, or CLI programs.
# Headers install to include/libxml2/libxml/; set out_include_dir accordingly
# so <libxml/parser.h> resolves without an extra path prefix.
cmake(
    name = "libxml2",
    lib_source = "@libxml2_src//:all",
    out_static_libs = ["libxml2.a"],
    out_include_dir = "include/libxml2",
    cache_entries = {
        "BUILD_SHARED_LIBS": "OFF",
        "LIBXML2_WITH_PYTHON": "OFF",
        "LIBXML2_WITH_ICU": "OFF",
        "LIBXML2_WITH_LZMA": "OFF",
        "LIBXML2_WITH_ZLIB": "OFF",
        "LIBXML2_WITH_TESTS": "OFF",
        "LIBXML2_WITH_PROGRAMS": "OFF",
        "CMAKE_INSTALL_LIBDIR": "lib",
    },
    visibility = ["//visibility:public"],
)

# ---- nghttp2 1.64.0 (http_archive) ----
# HTTP/2 protocol library.  libcurl links this for HTTP/2 transport support,
# which we need to call the UniFi MSR gRPC service on 127.0.0.1:7700.
# ENABLE_LIB_ONLY builds just libnghttp2.a (no apps/examples/tests).
cmake(
    name = "nghttp2",
    lib_source = "@nghttp2_src//:all",
    out_static_libs = ["libnghttp2.a"],
    cache_entries = {
        "ENABLE_LIB_ONLY": "ON",
        "BUILD_STATIC_LIBS": "ON",
        "BUILD_SHARED_LIBS": "OFF",
        "ENABLE_DOC": "OFF",
        "ENABLE_FAILMALLOC": "OFF",
        "ENABLE_APP": "OFF",
        "ENABLE_HPACK_TOOLS": "OFF",
        "ENABLE_EXAMPLES": "OFF",
        "ENABLE_PYTHON_BINDINGS": "OFF",
        "BUILD_TESTING": "OFF",
        "CMAKE_INSTALL_LIBDIR": "lib",
        "CMAKE_POSITION_INDEPENDENT_CODE": "ON",
    },
    visibility = ["//visibility:public"],
)

# ---- libcurl (git submodule: third_party/curl) ----
# HTTP/HTTPS only; OpenSSL backend; all other protocols disabled.
# HTTP/2 is enabled via nghttp2 so we can talk gRPC to the MSR service.
cmake(
    name = "libcurl",
    lib_source = "@curl_src//:all",
    deps = [":openssl", ":nghttp2"],
    out_static_libs = ["libcurl.a"],
    cache_entries = {
        "BUILD_SHARED_LIBS": "OFF",
        "BUILD_STATIC_LIBS": "ON",
        "BUILD_CURL_EXE": "OFF",
        "BUILD_TESTING": "OFF",
        "CURL_USE_PKGCONFIG": "OFF",
        "CURL_USE_OPENSSL": "ON",
        "CURL_USE_GNUTLS": "OFF",
        "CURL_USE_MBEDTLS": "OFF",
        "CURL_USE_LIBSSH2": "OFF",
        "CURL_USE_LIBPSL": "OFF",
        "CURL_ZLIB": "OFF",
        "CURL_DISABLE_FTP": "ON",
        "CURL_DISABLE_SMTP": "ON",
        "CURL_DISABLE_IMAP": "ON",
        "CURL_DISABLE_POP3": "ON",
        "CURL_DISABLE_TELNET": "ON",
        "CURL_DISABLE_TFTP": "ON",
        "CURL_DISABLE_MQTT": "ON",
        "CURL_DISABLE_DICT": "ON",
        "CURL_DISABLE_GOPHER": "ON",
        "CURL_DISABLE_LDAP": "ON",
        "CURL_DISABLE_LDAPS": "ON",
        "CURL_DISABLE_RTSP": "ON",
        "CURL_DISABLE_SMB": "ON",
        "CURL_DISABLE_WEBSOCKETS": "ON",
        "USE_NGHTTP2": "ON",
        "CURL_BROTLI": "OFF",
        "CURL_ZSTD": "OFF",
        "USE_LIBIDN2": "OFF",
        "OPENSSL_ROOT_DIR": "$$EXT_BUILD_DEPS$$/openssl",
        "NGHTTP2_INCLUDE_DIR": "$$EXT_BUILD_DEPS$$/nghttp2/include",
        "NGHTTP2_LIBRARY": "$$EXT_BUILD_DEPS$$/nghttp2/lib/libnghttp2.a",
        "CMAKE_INSTALL_LIBDIR": "lib",
    },
    visibility = ["//visibility:public"],
)
