#!/bin/bash
set -e
python3 -m cpplint src/*.cpp src/*.hpp test/*.cpp test/*.hpp
scripts/bz test --config=x86 //test:test_onvif_listener //test:test_ubv_thumbnail

# Docker ARM64 build -- validates the sysroot setup on ubuntu:24.04 (clang-18).
# Skipped silently when Docker is not available or not running.
if docker info &>/dev/null 2>&1; then
    echo "[pre-push] Docker available -- verifying ARM64 build..."
    ./build-in-docker.sh --arm64
else
    echo "[pre-push] Docker not available -- skipping ARM64 Docker build"
fi
