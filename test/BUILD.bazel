    name = "test_onvif_listener",
    srcs = ["test_onvif_listener.cpp"],
    env = {"TSAN_OPTIONS": "suppressions=$(location //test:tsan_suppressions)"},
    args = [
        "$(location //test:hikvision_raw_log)",
        "$(location //test:dahua_raw_log)",
        "$(location //test:cell_motion_raw_log)",
        "$(location //test:cell_motion_no_events_raw_log)",
