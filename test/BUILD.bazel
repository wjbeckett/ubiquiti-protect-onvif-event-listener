        "$(location //test:unvr_1_47_raw_log)",
        "$(location //test:reolink_bullet_raw_log)",
    ],
    data = [
        "//test:tsan_suppressions",
        "//test:hikvision_raw_log",
        "//test:dahua_raw_log",
        "//test:cell_motion_raw_log",
        "//test:cell_motion_no_events_raw_log",
        "//test:thingino_raw_log",
        "//test:html_404_raw_log",
        "//test:unvr_78_raw_log",
        "//test:unvr_119_raw_log",
        "//test:unvr_173_raw_log",
        "//test:unvr_227_raw_log",
        "//test:unvr_245_raw_log",
        "//test:unvr_251_raw_log",
        "//test:unvr_1_45_raw_log",
        "//test:unvr_1_47_raw_log",
        "//test:reolink_bullet_raw_log",
    ],
    deps = [
        "//:onvif_listener",
        ":camera_emulators",
        ":onvif_camera_emulator",
        "@com_google_absl//absl/status:status",
        "@com_google_absl//absl/status:statusor",
    ],
)

